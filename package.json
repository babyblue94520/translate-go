{
  "name": "translate-go",
  "version": "1.0.5",
  "description": "前端翻譯工具",
  "main": "./dist/translate-go/lib.js",
  "typings": "./dist/translate-go/lib.d.ts",
  "author": "clarewu",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/babyblue94520/translate-go.git"
  },
  "scripts": {
    "ng": "ng",
    "build": "npm run toolbar && npm run go",
    "rollupbuild": "rollup -c rollup.config.js --no-conflict",
    "rollupbuild:min": "rollup -c rollup.config.min.js",
    "start": "ng serve --port 4300",
    "go": "tsc -p src/translate-go/tsconfig.go.json",
    "toolbar": "ng build --prod --base-href /translate-go/dist/ && gulp concat",
    "http": "ng build --prod --output-hashing=none && gulp && http-server --gzip",
    "test": "ng test",
    "lint": "ng lint",
    "e2e": "ng e2e"
  },
  "private": false,
  "dependencies": {
    "@angular-devkit/build-ng-packagr": "^0.1002.0",
    "@angular/animations": "~9.0.7",
    "@angular/common": "~9.0.7",
    "@angular/compiler": "~9.0.7",
    "@angular/core": "~9.0.7",
    "@angular/elements": "^11.0.2",
    "@angular/forms": "~9.0.7",
    "@angular/platform-browser": "~9.0.7",
    "@angular/platform-browser-dynamic": "~9.0.7",
    "@angular/router": "~9.0.7",
    "core-js": "^2.5.4",
    "document-register-element": "^1.14.10",
    "elements-zone-strategy": "^7.0.0",
    "rxjs": "~6.5.4",
    "zone.js": "~0.10.2"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "~0.900.6",
    "@angular/cdk": "^9.2.4",
    "@angular/cli": "~9.0.6",
    "@angular/compiler-cli": "~9.0.7",
    "@angular/language-service": "~9.0.7",
    "@types/jasmine": "~2.8.8",
    "@types/jasminewd2": "~2.0.3",
    "@types/node": "^12.12.47",
    "codelyzer": "^5.1.2",
    "gulp": "^4.0.2",
    "gulp-concat": "^2.6.1",
    "gulp-string-replace": "^1.1.2",
    "gulp-uglify": "^3.0.1",
    "http-server": "^0.11.1",
    "jasmine-core": "~2.99.1",
    "jasmine-spec-reporter": "~4.2.1",
    "karma": "^5.0.4",
    "karma-chrome-launcher": "~2.2.0",
    "karma-coverage-istanbul-reporter": "~2.0.1",
    "karma-jasmine": "~1.1.2",
    "karma-jasmine-html-reporter": "^0.2.2",
    "protractor": "^6.0.0",
    "rollup-plugin-buble": "^0.19.4",
    "rollup-plugin-node-resolve": "^3.4.0",
    "rollup-plugin-typescript": "^1.0.0",
    "rollup-plugin-uglify-es": "0.0.1",
    "ts-node": "~7.0.0",
    "tslint": "~5.11.0",
    "typescript": "~3.7.5"
  },
  "resolutions": {
    "graceful-fs": "^4.2.4"
  }
}